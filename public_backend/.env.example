FLASK_DEBUG=1

PUBLIC_API_KEYS=replace_with_key_1,replace_with_key_2

MYSQL_HOST=IP_HOST
MYSQL_PORT=PORT
MYSQL_DB=DB_NAME
MYSQL_USER=USER_NAME
MYSQL_PASS=CHANGE_ME

# PostgreSQL (para endpoints /api/public/consolidado/*)
# Usa DATABASE_URL o este bloque POSTGRES_*
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASS=CHANGE_ME
POSTGRES_SSLMODE=

FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173,https://gestionderiesgos.gob.ec,https://www.gestionderiesgos.gob.ec
